{
  "$schema": "https://opencode.ai/config.json",
  "agent": {
    "build": {
      "description": "Full development work with all tools enabled",
      "mode": "primary",
      "model": "zai-coding-plan/glm-5-turbo",
      "tools": {
        "bash": true,
        "edit": true,
        "write": true
      }
    },
    "delivery-backend-engineer": {
      "description": "Backend implementation specialist",
      "mode": "subagent",
      "model": "zai-coding-plan/glm-5",
      "prompt": "{file:.opencode/agents/delivery-backend-engineer.md}",
      "tools": {
        "read": true
      }
    },
    "delivery-code-reviewer": {
      "description": "Code quality and pattern compliance reviewer",
      "mode": "subagent",
      "model": "zai-coding-plan/glm-5.1",
      "prompt": "{file:.opencode/agents/delivery-code-reviewer.md}",
      "tools": {
        "read": true
      }
    },
    "delivery-database-engineer": {
      "description": "Database schema and migration specialist",
      "mode": "subagent",
      "model": "zai-coding-plan/glm-4.7",
      "prompt": "{file:.opencode/agents/delivery-database-engineer.md}",
      "tools": {
        "read": true
      }
    },
    "delivery-debugger": {
      "description": "Diagnosis and system state inspection specialist",
      "mode": "subagent",
      "model": "zai-coding-plan/glm-5.1",
      "prompt": "{file:.opencode/agents/delivery-debugger.md}",
      "tools": {
        "read": true
      }
    },
    "delivery-devops-engineer": {
      "description": "CI/CD and infrastructure specialist",
      "mode": "subagent",
      "model": "zai-coding-plan/glm-5",
      "prompt": "{file:.opencode/agents/delivery-devops-engineer.md}",
      "tools": {
        "read": true
      }
    },
    "delivery-frontend-engineer": {
      "description": "Frontend UI and styling specialist",
      "mode": "subagent",
      "model": "zai-coding-plan/glm-5.1",
      "prompt": "{file:.opencode/agents/delivery-frontend-engineer.md}",
      "tools": {
        "read": true
      }
    },
    "delivery-governance-checker": {
      "description": "Compliance and governance rule enforcement",
      "mode": "subagent",
      "model": "zai-coding-plan/glm-5",
      "prompt": "{file:.opencode/agents/delivery-governance-checker.md}",
      "tools": {
        "read": true
      }
    },
    "delivery-implementation-expert": {
      "description": "Focused implementation and drafting expert",
      "mode": "subagent",
      "model": "zai-coding-plan/glm-5",
      "prompt": "{file:.opencode/agents/delivery-implementation-expert.md}",
      "tools": {
        "read": true
      }
    },
    "delivery-mobile-engineer": {
      "description": "Mobile application development specialist",
      "mode": "subagent",
      "model": "zai-coding-plan/glm-5",
      "prompt": "{file:.opencode/agents/delivery-mobile-engineer.md}",
      "tools": {
        "read": true
      }
    },
    "delivery-qa-engineer": {
      "description": "Quality assurance and testing specialist",
      "mode": "subagent",
      "model": "zai-coding-plan/glm-4.7",
      "prompt": "{file:.opencode/agents/delivery-qa-engineer.md}",
      "tools": {
        "read": true
      }
    },
    "delivery-strategic-architect": {
      "description": "High-level architectural design specialist",
      "mode": "subagent",
      "model": "zai-coding-plan/glm-5.1",
      "prompt": "{file:.opencode/agents/delivery-strategic-architect.md}",
      "tools": {
        "read": true
      }
    },
    "delivery-system-architect": {
      "description": "System architecture and infrastructure designer",
      "mode": "subagent",
      "model": "zai-coding-plan/glm-5.1",
      "prompt": "{file:.opencode/agents/delivery-system-architect.md}",
      "tools": {
        "read": true
      }
    },
    "delivery-ux-designer": {
      "description": "User experience and interface designer",
      "mode": "subagent",
      "model": "zai-coding-plan/glm-5",
      "prompt": "{file:.opencode/agents/delivery-ux-designer.md}",
      "tools": {
        "read": true
      }
    },
    "plan": {
      "description": "Analysis and planning without making changes",
      "mode": "primary",
      "model": "zai-coding-plan/glm-5-turbo",
      "permission": {
        "bash": "ask",
        "edit": "ask"
      }
    },
    "playwright-test-generator": {
      "description": "Use this agent when you need to create automated browser tests using Playwright",
      "mode": "subagent",
      "model": "zai-coding-plan/glm-5",
      "prompt": "{file:.opencode/prompts/playwright-test-generator.md}",
      "tools": {
        "glob": true,
        "grep": true,
        "ls": true,
        "playwright-test*browser_click": true,
        "playwright-test*browser_drag": true,
        "playwright-test*browser_evaluate": true,
        "playwright-test*browser_file_upload": true,
        "playwright-test*browser_handle_dialog": true,
        "playwright-test*browser_hover": true,
        "playwright-test*browser_navigate": true,
        "playwright-test*browser_press_key": true,
        "playwright-test*browser_select_option": true,
        "playwright-test*browser_snapshot": true,
        "playwright-test*browser_type": true,
        "playwright-test*browser_verify_element_visible": true,
        "playwright-test*browser_verify_list_visible": true,
        "playwright-test*browser_verify_text_visible": true,
        "playwright-test*browser_verify_value": true,
        "playwright-test*browser_wait_for": true,
        "playwright-test*generator_read_log": true,
        "playwright-test*generator_setup_page": true,
        "playwright-test*generator_write_test": true,
        "read": true
      }
    },
    "playwright-test-healer": {
      "description": "Use this agent when you need to debug and fix failing Playwright tests",
      "mode": "subagent",
      "model": "zai-coding-plan/glm-5",
      "prompt": "{file:.opencode/prompts/playwright-test-healer.md}",
      "tools": {
        "edit": true,
        "glob": true,
        "grep": true,
        "ls": true,
        "playwright-test*browser_console_messages": true,
        "playwright-test*browser_evaluate": true,
        "playwright-test*browser_generate_locator": true,
        "playwright-test*browser_network_requests": true,
        "playwright-test*browser_snapshot": true,
        "playwright-test*test_debug": true,
        "playwright-test*test_list": true,
        "playwright-test*test_run": true,
        "read": true,
        "write": true
      }
    },
    "playwright-test-planner": {
      "description": "Use this agent when you need to create comprehensive test plan for a web application or website",
      "mode": "subagent",
      "model": "zai-coding-plan/glm-5",
      "prompt": "{file:.opencode/prompts/playwright-test-planner.md}",
      "tools": {
        "glob": true,
        "grep": true,
        "ls": true,
        "playwright-test*browser_click": true,
        "playwright-test*browser_close": true,
        "playwright-test*browser_console_messages": true,
        "playwright-test*browser_drag": true,
        "playwright-test*browser_evaluate": true,
        "playwright-test*browser_file_upload": true,
        "playwright-test*browser_handle_dialog": true,
        "playwright-test*browser_hover": true,
        "playwright-test*browser_navigate": true,
        "playwright-test*browser_navigate_back": true,
        "playwright-test*browser_network_requests": true,
        "playwright-test*browser_press_key": true,
        "playwright-test*browser_run_code": true,
        "playwright-test*browser_select_option": true,
        "playwright-test*browser_snapshot": true,
        "playwright-test*browser_take_screenshot": true,
        "playwright-test*browser_type": true,
        "playwright-test*browser_wait_for": true,
        "playwright-test*planner_save_plan": true,
        "playwright-test*planner_setup_page": true,
        "read": true
      }
    }
  },
  "mcp": {
    "playwright-test": {
      "command": [
        "npx",
        "playwright",
        "run-test-mcp-server"
      ],
      "enabled": true,
      "type": "local"
    },
    "stratus": {
      "command": [
        "stratus",
        "mcp-serve"
      ],
      "enabled": true,
      "environment": {
        "STRATUS_EXECUTOR": "oc"
      },
      "type": "local"
    }
  },
  "plugin": [
    ".opencode/plugin/stratus.ts"
  ],
  "tools": {
    "playwright*": false
  }
}
